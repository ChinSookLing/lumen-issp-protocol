{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Lumen Feedback Entry",
  "description": "SPEG-compliant feedback schema. No original text, no identity.",
  "type": "object",
  "required": ["type", "pattern_id", "tier"],
  "properties": {
    "type": {
      "type": "string",
      "enum": ["confirm", "dismiss", "fp", "fn"],
      "description": "Feedback type"
    },
    "pattern_id": {
      "type": "string",
      "pattern": "^P[0-9]{2}$",
      "description": "Pattern ID (P01-P09)"
    },
    "flag_id": {
      "type": ["string", "null"],
      "description": "L2b flag ID if applicable"
    },
    "tier": {
      "type": "integer",
      "minimum": 0,
      "maximum": 8,
      "description": "Detection tier"
    },
    "confidence_before": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Confidence score at time of detection"
    },
    "note": {
      "type": "string",
      "maxLength": 200,
      "description": "Optional operator note (not end-user text)"
    }
  },
  "additionalProperties": false
}
