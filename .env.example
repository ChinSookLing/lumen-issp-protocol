# ============================================
# Lumen ISSP Protocol — Environment Configuration
# Copy this file to .env and fill in your values
# ============================================

# --- Required: Telegram Bot ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# --- Required: Server ---
PORT=3000
NODE_ENV=production

# --- Deployment Mode ---
# "cloud" = Render/Railway/Fly.io (auto-managed)
# "local" = Docker self-host (you manage)
DEPLOY_MODE=local

# --- Optional: Webhook (Cloud mode) ---
# WEBHOOK_URL=https://your-domain.com/webhook

# --- Optional: Dashboard ---
DASHBOARD_ENABLED=true
DASHBOARD_PORT=3001

# --- Optional: DMS (Dead Man's Switch) ---
# DMS_ENABLED=false
# DMS_EMAIL_TO=your-council-email@proton.me
# DMS_IDLE_DAYS=14

# --- Optional: Feedback Pipeline ---
# FEEDBACK_ENABLED=true
# FEEDBACK_STORE=local
# FEEDBACK_PATH=./data/feedback.json

# --- Optional: Metrics ---
# METRICS_ENABLED=true
# METRICS_PATH=./data/metrics.json
# METRICS_NIGHTLY_CRON=0 3 * * *

# --- Version Info (auto-set by release script) ---
LUMEN_VERSION=1.0.0
