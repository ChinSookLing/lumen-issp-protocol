{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "forecast-to-alert.v1",
  "title": "Forecast-to-Alert Contract v1",
  "description": "L3 forecast-engine output → L4 alert-engine input contract. Node-05 design (Sprint 8), Node-01 implementation.",
  "type": "object",
  "required": ["time_utc", "chat_id", "window", "forecast", "evidence_ids", "build_fingerprint"],
  "properties": {
    "time_utc": {
      "type": "string",
      "description": "ISO 8601 timestamp of forecast generation"
    },
    "chat_id": {
      "type": "string",
      "description": "Chat/group identifier"
    },
    "window": {
      "type": "object",
      "required": ["from_utc", "to_utc", "size"],
      "properties": {
        "from_utc": { "type": "string" },
        "to_utc": { "type": "string" },
        "size": { "type": "integer", "enum": [7, 30, 90] }
      }
    },
    "forecast": {
      "type": "object",
      "required": ["trend", "intensity", "gate_hit", "top_patterns"],
      "properties": {
        "trend": { "type": "string", "enum": ["rising", "stable", "declining"] },
        "intensity": { "type": "number", "minimum": 0, "maximum": 1 },
        "gate_hit": { "type": "integer", "minimum": 0, "maximum": 3 },
        "top_patterns": {
          "type": "array",
          "items": { "type": "string" },
          "maxItems": 9
        }
      }
    },
    "evidence_ids": {
      "type": "array",
      "items": { "type": "string" }
    },
    "build_fingerprint": {
      "type": "object",
      "required": ["build_id", "commit_hash", "operator_mode"],
      "properties": {
        "build_id": { "type": "string" },
        "commit_hash": { "type": "string" },
        "operator_mode": { "type": "string", "enum": ["live", "test", "audit"] }
      }
    }
  },
  "additionalProperties": false
}
