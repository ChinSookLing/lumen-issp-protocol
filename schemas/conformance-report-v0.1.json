{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "conformance-report-v0.1",
  "title": "Lumen ISSP Conformance Report v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "protocol", "implementation", "run", "results", "verdict"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "conformance-report-v0.1"
    },
    "protocol": {
      "type": "object",
      "additionalProperties": false,
      "required": ["protocol_id", "protocol_version", "schema_set"],
      "properties": {
        "protocol_id": { "type": "string", "const": "lumen-issp" },
        "protocol_version": { "type": "string", "pattern": "^0\\.[0-9]+(\\.[0-9]+)?$" },
        "schema_set": {
          "type": "object",
          "description": "Versions/ids of key schemas used in this conformance run.",
          "additionalProperties": { "type": "string" }
        },
        "spec_refs": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Optional references to spec docs (paths or identifiers)."
        }
      }
    },
    "implementation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["impl_id", "impl_version"],
      "properties": {
        "impl_id": {
          "type": "string",
          "description": "Implementation identifier, e.g., org/repo or package name."
        },
        "impl_version": {
          "type": "string",
          "description": "Implementation version (semver recommended)."
        },
        "commit": { "type": "string", "description": "Optional VCS commit hash." },
        "build_fingerprint": {
          "type": "string",
          "description": "Optional build hash (docker image digest, artifact hash, etc.)."
        },
        "runtime": {
          "type": "object",
          "additionalProperties": true,
          "description": "Optional runtime metadata (node version, os, etc.)."
        }
      }
    },
    "run": {
      "type": "object",
      "additionalProperties": false,
      "required": ["started_at_utc", "finished_at_utc"],
      "properties": {
        "started_at_utc": { "type": "string", "format": "date-time" },
        "finished_at_utc": { "type": "string", "format": "date-time" },
        "profile": {
          "type": "string",
          "default": "DEFAULT",
          "description": "Optional conformance profile (DEFAULT/SOCIAL/FINANCIAL/SAFETY_CRITICAL)."
        },
        "command": { "type": "string", "description": "Command used to run conformance." },
        "artifacts": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "report_md": { "type": "string" },
            "logs_dir": { "type": "string" },
            "traces_dir": { "type": "string" }
          }
        }
      }
    },
    "results": {
      "type": "object",
      "additionalProperties": false,
      "required": ["gates"],
      "properties": {
        "gates": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/gateResult" }
        },
        "metrics": {
          "type": "object",
          "description": "Optional metric outputs (rates, accuracies).",
          "additionalProperties": { "type": "number" }
        },
        "regression_count": {
          "type": "integer",
          "minimum": 0,
          "description": "Convenience field; if present should match the relevant gate output."
        }
      }
    },
    "verdict": {
      "type": "string",
      "enum": ["PASS", "FAIL", "CONDITIONAL_PASS"]
    },
    "notes": {
      "type": "string",
      "description": "Optional human notes."
    }
  },
  "$defs": {
    "gateResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["gate_id", "status", "hard_gate"],
      "properties": {
        "gate_id": {
          "type": "string",
          "description": "Stable gate identifier, e.g., schema_validation, contract_tests, trs_vectors, regression_gate."
        },
        "status": {
          "type": "string",
          "enum": ["pass", "fail", "skip"]
        },
        "hard_gate": {
          "type": "boolean",
          "description": "If true and status==fail, overall verdict must be FAIL."
        },
        "summary": {
          "type": "string",
          "description": "One-line summary."
        },
        "details": {
          "type": "object",
          "description": "Optional structured details; keep machine-readable.",
          "additionalProperties": true
        },
        "artifacts": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Paths/refs to supporting artifacts."
        }
      }
    }
  }
}
