{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "manifest-v0.1",
  "title": "Delivered Artifact Manifest v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "manifest_id", "request_id", "decision_id", "generated_at_utc", "delivered_items"],
  "properties": {
    "schema_version": { "const": "manifest-v0.1" },
    "manifest_id": { "type": "string" },
    "request_id": { "type": "string" },
    "decision_id": { "type": "string" },
    "generated_at_utc": { "type": "string", "format": "date-time" },
    "delivery_channel": {
      "type": "string",
      "enum": ["email", "portal", "physical_media", "in_person", "unknown"],
      "default": "unknown"
    },
    "delivered_items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["item_id", "item_type", "sha256"],
        "properties": {
          "item_id": { "type": "string" },
          "item_type": {
            "type": "string",
            "enum": [
              "LEVEL_0_FINGERPRINT_BUNDLE",
              "LEVEL_1_REDACTED_EXCERPT_BUNDLE",
              "LEVEL_2_ENCRYPTED_ARCHIVE",
              "AGGREGATE_REPORT",
              "CONFORMANCE_REPORT",
              "OTHER"
            ]
          },
          "sha256": { "type": "string" },
          "size_bytes": { "type": "integer", "minimum": 0 },
          "retention_tier": { "type": "string", "enum": ["LEVEL_0", "LEVEL_1", "LEVEL_2"] },
          "contains_raw_text": { "type": "boolean", "default": false },
          "pii_redaction_applied": { "type": "boolean", "default": true },
          "notes": { "type": "string" }
        }
      }
    },
    "integrity": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "hash_root_ref": { "type": "string" },
        "signatures": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["signer", "signature_type", "signature"],
            "properties": {
              "signer": { "type": "string" },
              "signature_type": { "type": "string", "enum": ["pgp", "x509", "hmac", "other"] },
              "signature": { "type": "string" }
            }
          }
        }
      }
    },
    "access_log_ref": { "type": "string" },
    "notes": { "type": "string" }
  }
}
