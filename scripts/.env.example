# Lumen Protocol — Environment Variables
# Step 17A Release Packaging
# Copy to .env and fill in your values

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Dashboard
DASHBOARD_TOKEN=your_dashboard_token_here

# Server
PORT=3000
NODE_ENV=production

# Release Notice (node-local, no email collection)
RELEASE_NOTICE_ENABLED=true
